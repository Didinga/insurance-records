# Copy this file to .env and fill in real values.
# Never commit the actual .env file (it's already in .gitignore).

# Generate a real one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-key

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts, e.g. example.com,www.example.com
DJANGO_ALLOWED_HOSTS=